generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?   @unique
  password      String
  avatarUrl     String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  projects      Project[]
  otps          Otp[]
}

model Otp {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  identifier String   // email address
  code       String
  purpose    String   // "signup" | "login" | "reset"
  expiresAt  DateTime
  consumed   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([identifier, purpose])
}

model Project {
  id                     String   @id @default(uuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id])
  projectName            String
  githubUrl              String?
  minScoreThreshold      Int?     @default(70)
  maxComplexityThreshold Int?     @default(15)
  createdAt              DateTime @default(now())
  reviews                Review[]
}

model Review {
  id                String          @id @default(uuid())
  projectId         String
  project           Project         @relation(fields: [projectId], references: [id])
  reviewType        String
  overallScore      Int?
  passedQualityGate Boolean?
  summary           String?
  embedding         String?         @db.Text
  createdAt         DateTime        @default(now())
  findings          ReviewFinding[]
}

model ReviewFinding {
  id           String  @id @default(uuid())
  reviewId     String
  review       Review  @relation(fields: [reviewId], references: [id])
  severity     String
  issue        String
  explanation  String
  suggestedFix String?
  fileName     String?
  lineNumber   Int?
}